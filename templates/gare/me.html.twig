{% extends 'base.html.twig' %}
{% import _self as t %}

{% block title %}Ma gare{% endblock %}

{# En-tête de section : barre d'accent + titre + sous-titre. #}
{% macro sectionHead(title, subtitle) %}
    <div class="flex items-center gap-2.5">
        <span class="h-7 w-1 rounded-full bg-primary"></span>
        <div>
            <h2 class="text-base font-semibold leading-none tracking-[-0.2px]">{{ title }}</h2>
            {% if subtitle %}<p class="mt-1 text-xs text-muted-foreground">{{ subtitle }}</p>{% endif %}
        </div>
    </div>
{% endmacro %}

{# Carte d'un car suivi. Lien vers la fiche voyage seulement si l'agent a le droit (VOYAGE_VOIR). #}
{% macro carItem(v, kind, canShow) %}
    {% set inner %}
    <div class="py-2.5">
        <div class="flex items-center gap-3">
            <div class="flex size-9 shrink-0 items-center justify-center rounded-lg {{ kind == 'vers' ? 'bg-emerald-500/10 text-emerald-600 dark:text-emerald-400' : 'bg-blue-500/10 text-blue-600 dark:text-blue-400' }}">
                {% if kind == 'vers' %}
                <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 17V3"/><path d="m6 11 6 6 6-6"/><path d="M19 21H5"/></svg>
                {% else %}
                <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21V7"/><path d="m6 13 6-6 6 6"/><path d="M5 3h14"/></svg>
                {% endif %}
            </div>
            <div class="min-w-0 flex-1">
                <p class="text-sm leading-tight">
                    <span class="font-semibold">{{ v.car ?: v.codevoyage }}</span>
                    {% if v.car %}<span class="ml-1 font-mono text-xs text-muted-foreground">{{ v.codevoyage }}</span>{% endif %}
                </p>
                <p class="truncate text-xs text-muted-foreground">{{ v.provenance }} → {{ v.destination }}</p>
                {% if v.datedepartprevue %}
                <p class="flex items-center gap-1 truncate text-xs text-muted-foreground">
                    <svg class="size-3 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                    {{ date(v.datedepartprevue) <= date() ? 'Parti de' : 'Départ prévu de' }} {{ v.provenance }} à {{ v.datedepartprevue|date('H:i') }}
                </p>
                {% endif %}
                {% if v.commercial %}<p class="truncate text-xs text-violet-600 dark:text-violet-400">Commercial : {{ v.commercial }}</p>{% endif %}
            </div>
            <div class="shrink-0 text-right">
                {% if kind == 'vers' %}
                    <span class="inline-block rounded-full bg-emerald-500/10 px-2 py-0.5 text-xs font-medium text-emerald-700 dark:text-emerald-300">
                        {{ v.arrets <= 1 ? 'Prochain arrêt' : ('à ' ~ v.arrets ~ ' arrêts') }}
                    </span>
                {% else %}
                    <span class="inline-block rounded-full px-2 py-0.5 text-xs font-medium {{ v.aQuai ? 'bg-amber-500/10 text-amber-700 dark:text-amber-300' : 'bg-blue-500/10 text-blue-700 dark:text-blue-300' }}">
                        {{ v.aQuai ? 'À quai' : ('Parti · ' ~ v.arrets ~ (v.arrets > 1 ? ' arrêts' : ' arrêt')) }}
                    </span>
                {% endif %}
                {% if v.positionActuelle %}<p class="mt-1 text-[11px] text-muted-foreground">{{ v.positionActuelle }}</p>{% endif %}
            </div>
        </div>

        {# Mini-plan de ligne : noms des arrêts + 🚍 car à sa position · ⬤ ma gare #}
        {% if v.nbArrets is defined and v.nbArrets > 1 %}
        {% set carBg  = kind == 'vers' ? 'bg-emerald-600' : 'bg-blue-600' %}
        {% set lineOn = kind == 'vers' ? 'bg-emerald-500/60' : 'bg-blue-500/60' %}
        {% set dotOn  = kind == 'vers' ? 'bg-emerald-500/50' : 'bg-blue-500/50' %}
        {% set nameOn = kind == 'vers' ? 'text-emerald-700 dark:text-emerald-400' : 'text-blue-700 dark:text-blue-400' %}
        {# Lignes longues : on ne nomme que les arrêts clés (origine, ma gare, car, terminus) #}
        {% set condense = v.nbArrets > 6 %}
        <div class="mt-3 flex items-start">
            {% for i in 0..(v.nbArrets - 1) %}
            <div class="flex min-w-0 flex-1 flex-col items-center">
                <div class="relative flex h-5 w-full items-center justify-center">
                    {% if i > 0 %}<span class="absolute left-0 right-1/2 top-1/2 h-0.5 -translate-y-1/2 {{ i <= v.ordreCar ? lineOn : 'bg-border' }}"></span>{% endif %}
                    {% if i < v.nbArrets - 1 %}<span class="absolute left-1/2 right-0 top-1/2 h-0.5 -translate-y-1/2 {{ i < v.ordreCar ? lineOn : 'bg-border' }}"></span>{% endif %}
                    {% if i == v.ordreCar %}
                        <span class="relative z-10 flex size-5 items-center justify-center rounded-full text-white {{ carBg }} {{ i == v.ordreGare ? 'ring-2 ring-primary/40' : '' }}" title="Car ici · {{ v.etapes[i] }}">
                            <svg class="size-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M8 6v6"/><path d="M15 6v6"/><path d="M2 12h19.6"/><path d="M4 18V8a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v10"/><circle cx="7" cy="18" r="2"/><circle cx="16" cy="18" r="2"/></svg>
                        </span>
                    {% elseif i == v.ordreGare %}
                        <span class="relative z-10 size-3 rounded-full bg-primary ring-2 ring-primary/25" title="Ma gare · {{ v.etapes[i] }}"></span>
                    {% else %}
                        <span class="relative z-10 size-2.5 rounded-full {{ i < v.ordreCar ? dotOn : 'bg-border' }}" title="{{ v.etapes[i] }}"></span>
                    {% endif %}
                </div>
                {% set estCle = i == 0 or i == (v.nbArrets - 1) or i == v.ordreGare or i == v.ordreCar %}
                {% if not condense or estCle %}
                <span class="mt-1 max-w-full truncate text-[10px] leading-tight {{ i == v.ordreCar ? ('font-semibold ' ~ nameOn) : (i == v.ordreGare ? 'font-semibold text-primary' : 'text-muted-foreground') }}" title="{{ v.etapes[i] }}">{{ v.etapes[i] }}</span>
                {% endif %}
            </div>
            {% endfor %}
        </div>
        {% endif %}
    </div>
    {% endset %}
    {% if canShow %}
    <a href="{{ path('voyage.show', { id: v.voyageId }) }}" class="-mx-2 block rounded-lg px-2 transition-colors hover:bg-muted/40">{{ inner }}</a>
    {% else %}
    <div class="-mx-2 px-2">{{ inner }}</div>
    {% endif %}
{% endmacro %}

{% block body %}
{% if gare is null %}
<div class="max-w-[640px] mx-auto card p-8 text-center mt-6">
    <h1 class="text-2xl font-light mb-2">Ma gare</h1>
    <p class="text-muted-foreground">Vous n'êtes rattaché à aucune gare.</p>
</div>
{% else %}
{% set canShowVoyage = is_granted('VOYAGE_VOIR') %}
{% set nbVers = suivi.versMaGare|default([])|length %}
{% set nbDepuis = suivi.depuisMaGare|default([])|length %}
<div class="max-w-[1100px] mx-auto space-y-8">

    {# ── Hero ── #}
    <div class="relative overflow-hidden rounded-2xl border bg-card p-6">
        <div class="pointer-events-none absolute -right-10 -top-10 size-44 rounded-full bg-primary/5"></div>
        <div class="relative flex flex-wrap items-start justify-between gap-4">
            <div class="flex items-start gap-4">
                <div class="flex size-12 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary">
                    <svg class="size-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18"/><path d="M5 21V7l8-4v18"/><path d="M19 21V11l-6-4"/><path d="M9 9v.01"/><path d="M9 12v.01"/><path d="M9 15v.01"/><path d="M9 18v.01"/></svg>
                </div>
                <div class="min-w-0">
                    <p class="text-xs uppercase tracking-wide text-muted-foreground">Ma gare</p>
                    <h1 class="text-2xl font-semibold tracking-[-0.4px] leading-tight">{{ gare.libelle }}</h1>
                    <div class="mt-1 flex flex-wrap items-center gap-2 text-sm text-muted-foreground">
                        {% if gare.ville %}<span class="inline-flex items-center gap-1">
                            <svg class="size-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/></svg>
                            {{ gare.ville }}</span>{% endif %}
                        {% if gare.statut %}
                        <span class="rounded-full px-2 py-0.5 text-xs {{ gare.statut == 'ACTIF' ? 'bg-green-100 text-green-700 dark:bg-green-950 dark:text-green-300' : 'bg-amber-100 text-amber-700 dark:bg-amber-950 dark:text-amber-300' }}">
                            {{ gare.statut == 'ACTIF' ? 'Active' : gare.statut|capitalize }}
                        </span>
                        {% endif %}
                    </div>
                </div>
            </div>
            {# Mini-stat suivi (tout agent) #}
            <div class="flex items-center gap-4 rounded-xl border bg-muted/30 px-4 py-3">
                <div class="text-center">
                    <p class="text-xl font-semibold tabular-nums text-emerald-600 dark:text-emerald-400">{{ nbVers }}</p>
                    <p class="text-[11px] text-muted-foreground">en approche</p>
                </div>
                <div class="h-8 w-px bg-border"></div>
                <div class="text-center">
                    <p class="text-xl font-semibold tabular-nums text-blue-600 dark:text-blue-400">{{ nbDepuis }}</p>
                    <p class="text-[11px] text-muted-foreground">au départ</p>
                </div>
            </div>
        </div>
    </div>

    {# ── Suivi des cars (tout agent) ── #}
    <section>
        <div class="mb-4">{{ t.sectionHead('Suivi des cars', 'Cars en circulation desservant votre gare') }}</div>
        <div class="grid grid-cols-1 gap-4 lg:grid-cols-2">

            {# Vers ma gare #}
            <div class="card p-4">
                <div class="mb-2 flex items-center justify-between">
                    <p class="flex items-center gap-2 text-sm font-medium">
                        <span class="size-2 rounded-full bg-emerald-500"></span> Vers ma gare
                    </p>
                    <span class="text-xs text-muted-foreground">{{ nbVers }} car(s)</span>
                </div>
                {% if nbVers > 0 %}
                <ul class="divide-y divide-border">
                    {% for v in suivi.versMaGare %}<li>{{ t.carItem(v, 'vers', canShowVoyage) }}</li>{% endfor %}
                </ul>
                {% else %}
                <p class="py-6 text-center text-sm text-muted-foreground">Aucun car en approche</p>
                {% endif %}
            </div>

            {# Depuis ma gare #}
            <div class="card p-4">
                <div class="mb-2 flex items-center justify-between">
                    <p class="flex items-center gap-2 text-sm font-medium">
                        <span class="size-2 rounded-full bg-blue-500"></span> Depuis ma gare
                    </p>
                    <span class="text-xs text-muted-foreground">{{ nbDepuis }} car(s)</span>
                </div>
                {% if nbDepuis > 0 %}
                <ul class="divide-y divide-border">
                    {% for v in suivi.depuisMaGare %}<li>{{ t.carItem(v, 'depuis', canShowVoyage) }}</li>{% endfor %}
                </ul>
                {% else %}
                <p class="py-6 text-center text-sm text-muted-foreground">Aucun car au départ</p>
                {% endif %}
            </div>
        </div>
    </section>

    {# ── Recette de la gare (admin de gare uniquement) ── #}
    {% if stats %}
    {% set periodes = { 'jour': "Aujourd'hui", 'mois': 'Ce mois-ci', 'tout': 'Tout' } %}
    <section>
        <div class="mb-4 flex flex-wrap items-center justify-between gap-3">
            {{ t.sectionHead('Recette de la gare', 'Encaissements à votre gare') }}
            <div class="flex items-center gap-1 rounded-lg border bg-muted/30 p-0.5 text-sm">
                {% for key, label in periodes %}
                <a href="{{ path('gare.me', { periode: key }) }}"
                   class="rounded-md px-3 py-1 transition-colors {{ periode == key ? 'bg-card text-foreground font-medium shadow-sm' : 'text-muted-foreground hover:text-foreground' }}">
                    {{ label }}
                </a>
                {% endfor %}
            </div>
        </div>

        {% set totalOps = stats.billets.count + stats.courriers.count + stats.bagages.count %}
        <div class="grid grid-cols-1 gap-4 lg:grid-cols-3">
            {# Hero recette #}
            <div class="flex flex-col justify-center rounded-xl border bg-gradient-to-br from-primary/10 to-card p-5">
                <p class="text-xs text-muted-foreground">Total · {{ periodes[periode]|lower }}</p>
                <p class="mt-1 text-3xl font-semibold tabular-nums">{{ stats.recetteTotale|number_format(0, ',', ' ') }}</p>
                <p class="text-xs text-muted-foreground">FCFA · {{ totalOps }} opération(s)</p>
            </div>

            {# Graphe d'occupation — répartition de l'activité #}
            <div class="card flex flex-col p-4">
                <p class="mb-2 text-xs font-medium text-muted-foreground">Répartition de l'activité</p>
                {% if totalOps > 0 %}
                <canvas id="chartGareActivite" height="150" data-values="{{ [
                    {label: 'Billets', value: stats.billets.count},
                    {label: 'Courriers', value: stats.courriers.count},
                    {label: 'Bagages', value: stats.bagages.count}
                ]|json_encode }}"></canvas>
                {% else %}
                <p class="flex-1 content-center py-8 text-center text-sm text-muted-foreground">Aucune activité sur la période</p>
                {% endif %}
            </div>

            {# KPIs détaillés #}
            <div class="grid grid-cols-1 gap-3">
                {{ t.kpiRecette('Billets émis', stats.billets.count, stats.billets.recette, 'bg-sky-500') }}
                {{ t.kpiRecette('Courriers déposés', stats.courriers.count, stats.courriers.recette, 'bg-violet-500') }}
                {{ t.kpiRecette('Bagages enregistrés', stats.bagages.count, stats.bagages.recette, 'bg-amber-500') }}
            </div>
        </div>
    </section>
    {% endif %}

    {# ── Informations de la gare ── #}
    <section>
        <div class="mb-4">{{ t.sectionHead('Informations', 'Coordonnées de la gare') }}</div>
        <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
            {{ t.infoCard('user', 'Chef de gare', gare.chefgare) }}
            {{ t.infoCard('pin', 'Ville', gare.ville) }}
            {{ t.infoCard('phone', 'Contact 1', gare.contact1) }}
            {{ t.infoCard('phone', 'Contact 2', gare.contact2) }}
            {% if gare.datecreation is defined and gare.datecreation %}
            {{ t.infoCard('calendar', 'Date de création', gare.datecreation|date('d/m/Y')) }}
            {% endif %}
        </div>
        {% if gare.description %}
        <div class="card mt-3 flex gap-3 p-4">
            <div class="flex size-9 shrink-0 items-center justify-center rounded-lg bg-muted text-muted-foreground">
                <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="M16 13H8"/><path d="M16 17H8"/><path d="M10 9H8"/></svg>
            </div>
            <div class="min-w-0">
                <p class="text-xs text-muted-foreground">Description</p>
                <p class="font-medium">{{ gare.description }}</p>
            </div>
        </div>
        {% endif %}
    </section>

    {# ── Agents rattachés ── #}
    {% if is_granted('USER_VOIR') or is_granted('ROLE_SUPER_ADMIN') %}
    <section>
        <div class="mb-4 flex items-center justify-between gap-2">
            {{ t.sectionHead('Agents de la gare', users|length ~ ' agent(s) rattaché(s)') }}
        </div>

        {% if users|length > 0 %}
        <div class="card divide-y divide-border p-0">
            {% for u in users %}
            <div class="flex items-center gap-3 px-4 py-3 transition-colors hover:bg-muted/30">
                {# Avatar : photo réelle si dispo, sinon initiales #}
                {% if u.fileUrl is defined and u.fileUrl %}
                <img src="{{ api_url ~ '/media' ~ u.fileUrl ~ '?w=72&h=72&fm=jpg&fit=crop' }}" alt="{{ u.prenom }} {{ u.nom }}" class="size-9 shrink-0 rounded-full object-cover" />
                {% else %}
                <div class="flex size-9 shrink-0 items-center justify-center rounded-full bg-primary/10 text-xs font-semibold text-primary">
                    {{ u.prenom|slice(0,1)|upper }}{{ u.nom|slice(0,1)|upper }}
                </div>
                {% endif %}
                <div class="min-w-0 flex-1">
                    <p class="truncate text-sm font-medium">{{ u.prenom }} {{ u.nom }}</p>
                    <p class="truncate text-xs text-muted-foreground">{{ u.email }}</p>
                </div>
                {# Rôle #}
                <div class="hidden sm:block">
                    {% if u.founder %}
                        <span class="rounded-full bg-yellow-100 px-2.5 py-0.5 text-xs font-medium text-yellow-700 dark:bg-yellow-950 dark:text-yellow-300">👑 Fondateur</span>
                    {% elseif 'ROLE_ADMIN_GARE' in u.roles %}
                        <span class="rounded-full bg-blue-100 px-2.5 py-0.5 text-xs font-medium text-blue-700 dark:bg-blue-950 dark:text-blue-300">Admin de gare</span>
                    {% elseif 'ROLE_ADMIN' in u.roles %}
                        <span class="rounded-full bg-purple-100 px-2.5 py-0.5 text-xs font-medium text-purple-700 dark:bg-purple-950 dark:text-purple-300">Admin</span>
                    {% else %}
                        <span class="rounded-full bg-muted px-2.5 py-0.5 text-xs font-medium text-muted-foreground">Utilisateur</span>
                    {% endif %}
                </div>
                {# Statut (pastille) #}
                <span class="inline-flex items-center gap-1.5 text-xs {{ u.statut == 'ACTIF' ? 'text-green-600 dark:text-green-400' : 'text-red-600 dark:text-red-400' }}">
                    <span class="size-1.5 rounded-full {{ u.statut == 'ACTIF' ? 'bg-green-500' : 'bg-red-500' }}"></span>
                    {{ u.statut == 'ACTIF' ? 'Actif' : 'Suspendu' }}
                </span>
            </div>
            {% endfor %}
        </div>
        {% else %}
        <div class="card p-8 text-center">
            <p class="text-sm text-muted-foreground">Aucun agent rattaché à cette gare.</p>
        </div>
        {% endif %}
    </section>
    {% endif %}
</div>
{% endif %}
{% endblock %}

{% macro kpiRecette(label, count, recette, dot) %}
    <div class="card p-4">
        <div class="mb-1 flex items-center gap-2">
            <span class="size-2 rounded-full {{ dot }}"></span>
            <p class="text-xs text-muted-foreground">{{ label }}</p>
        </div>
        <p class="text-2xl font-semibold tabular-nums">{{ count }}</p>
        <p class="text-xs text-muted-foreground">{{ recette|number_format(0, ',', ' ') }} F</p>
    </div>
{% endmacro %}

{# Carte info : icône + label + valeur. #}
{% macro infoCard(icon, label, value) %}
    <div class="card flex items-center gap-3 p-4">
        <div class="flex size-9 shrink-0 items-center justify-center rounded-lg bg-muted text-muted-foreground">
            {% if icon == 'user' %}
            <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            {% elseif icon == 'pin' %}
            <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/></svg>
            {% elseif icon == 'calendar' %}
            <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/><path d="M8 2v4"/><path d="M16 2v4"/></svg>
            {% else %}
            <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.94.36 1.86.7 2.74a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.34-1.27a2 2 0 0 1 2.11-.45c.88.34 1.8.57 2.74.7A2 2 0 0 1 22 16.92z"/></svg>
            {% endif %}
        </div>
        <div class="min-w-0">
            <p class="text-xs text-muted-foreground">{{ label }}</p>
            <p class="truncate font-semibold">{{ value ?: '—' }}</p>
        </div>
    </div>
{% endmacro %}
