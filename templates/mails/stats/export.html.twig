<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'DejaVu Sans', sans-serif; font-size: 11px; color: #111; padding: 18px 22px; }
        h1 { font-size: 19px; margin-bottom: 2px; }
        .period { font-size: 10.5px; color: #555; margin-bottom: 14px; }
        h2 { font-size: 13px; margin: 16px 0 5px; padding-bottom: 3px; border-bottom: 1.5px solid #111; }
        table { width: 100%; border-collapse: collapse; margin-bottom: 6px; }
        th, td { border: 1px solid #bbb; padding: 3px 6px; text-align: left; font-size: 10px; vertical-align: top; }
        th { background: #efefef; font-weight: bold; }
        tr:nth-child(even) td { background: #fafafa; }
        td.num, th.num { text-align: right; }
        .empty { color: #888; font-style: italic; font-size: 10px; padding: 4px 0; }
        .footer { margin-top: 18px; padding-top: 6px; border-top: 1px solid #ddd; font-size: 8px; color: #888; text-align: center; }
    </style>
</head>
<body>
    <h1>{{ titre }}</h1>
    <div class="period">Période : {{ periode }} &nbsp;·&nbsp; Édité le {{ "now"|date('d/m/Y à H:i') }}</div>

    {% for s in sections %}
        <h2>{{ s.title }}</h2>
        {% if s.rows is empty %}
            <p class="empty">Aucune donnée sur la période.</p>
        {% else %}
            <table>
                {% if s.columns is defined and s.columns %}
                <thead>
                    <tr>
                        {% for c in s.columns %}<th{{ loop.index0 > 0 ? ' class="num"' : '' }}>{{ c }}</th>{% endfor %}
                    </tr>
                </thead>
                {% endif %}
                <tbody>
                    {% for row in s.rows %}
                    <tr>
                        {% for cell in row %}<td{{ loop.index0 > 0 ? ' class="num"' : '' }}>{{ cell is same as(null) ? '—' : (cell is iterable ? (cell|join(' ')) : cell) }}</td>{% endfor %}
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% endif %}
    {% endfor %}

    <div class="footer">iTransport — Export de statistiques</div>
</body>
</html>
