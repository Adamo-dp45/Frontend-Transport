<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    {#
        Reçu COURRIER — format thermique 80 mm (cf. PdfService::generate, défaut 'thermal').
        IMPORTANT : Dompdf ne supporte PAS flexbox. Toute mise en page sur 2 colonnes (en-tête,
        valeur/frais) passe donc par des <table>, sinon les blocs s'empilent.
    #}
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'DejaVu Sans', sans-serif;
            font-size: 11px;
            color: #000;
            width: 72mm;
            padding: 4mm;
        }

        /* ── En-tête : sigle + gare à gauche, téléphones + date à droite ── */
        .hdr { width: 100%; border-collapse: collapse; }
        .hdr td { vertical-align: top; padding: 0; }
        .hdr .r { text-align: right; }
        .sigle {
            font-size: 17px;
            font-weight: bold;
            letter-spacing: 1px;
            line-height: 1.1;
        }
        .gare {
            font-size: 11px;
            font-weight: bold;
            letter-spacing: 1px;
        }
        .tels { font-size: 10px; font-weight: bold; }
        .date { font-size: 11px; font-weight: bold; margin-top: 1px; }

        /* ── Titre ── */
        .title {
            text-align: center;
            font-size: 17px;
            font-weight: bold;
            letter-spacing: 2px;
            margin: 7px 0 5px;
        }

        /* ── Bandeau d'état (perdu / annulé) — hors cas nominal ── */
        .statut-banner {
            background: #000;
            color: #fff;
            text-align: center;
            font-size: 14px;
            font-weight: bold;
            letter-spacing: 2px;
            padding: 4px 2px;
            margin: 6px 0;
        }

        /* ── Lignes d'information ── */
        .line { font-size: 12px; font-weight: bold; letter-spacing: 1px; margin: 4px 0; }
        .line .v { margin-left: 8px; }

        .vf { width: 100%; border-collapse: collapse; margin: 4px 0; }
        .vf td { font-size: 12px; font-weight: bold; letter-spacing: 1px; padding: 0; }
        .vf .big { font-size: 15px; }

        .code {
            font-size: 20px;
            font-weight: bold;
            letter-spacing: 2px;
            margin: 7px 0;
        }
        .code .lbl { font-size: 14px; }

        /* ── Expéditeur / Destinataire ── */
        .sect {
            text-align: center;
            font-size: 12px;
            font-weight: bold;
            letter-spacing: 1px;
            margin: 7px 0 1px;
        }
        .sect-v {
            text-align: center;
            font-size: 13px;
            font-weight: bold;
            letter-spacing: 1px;
        }
        .sect-c { text-align: center; font-size: 11px; font-weight: bold; margin-top: 1px; }

        .ref { font-size: 13px; font-weight: bold; letter-spacing: 1px; margin: 7px 0 4px; }
        .suivi { font-size: 12px; font-weight: bold; letter-spacing: 1px; margin: 4px 0 6px; }
        .suivi .big { font-size: 14px; margin-left: 8px; }

        /* ── Liste des colis ── */
        .table-title {
            text-align: center;
            font-size: 11px;
            font-weight: bold;
            letter-spacing: 1px;
            border: 1px solid #000;
            border-bottom: none;
            padding: 2px;
        }
        .colis { width: 100%; border-collapse: collapse; font-size: 10px; }
        .colis th, .colis td {
            border: 1px solid #000;
            padding: 2px 4px;
            text-align: left;
            font-weight: bold;
        }
        .colis th { letter-spacing: 1px; }

        /* ── Pied ── */
        .footer { font-size: 8px; text-align: center; font-weight: bold; margin-top: 7px; }
        .footer p { margin-top: 2px; }
    </style>
</head>
<body>

    {# Accès défensifs : l'entreprise ou une gare peut manquer selon la réponse API (strict_variables). #}
    {% set ent = entreprise|default({}) %}
    {% set marque = ent.sigle|default(ent.libelle|default('')) %}
    {% set garedepart = courrier.garedepart|default(null) %}
    {% set garearrivee = courrier.garearrivee|default(null) %}

    {# ── En-tête ── #}
    <table class="hdr">
        <tr>
            <td>
                <div class="sigle">{{ marque|upper }}</div>
                <div class="gare">{{ garedepart ? garedepart.libelle|upper : '' }}</div>
            </td>
            <td class="r">
                {% set tels = [ent.contact1|default(''), ent.contact2|default('')]|filter(t => t is not empty) %}
                {% if tels|length %}<div class="tels">{{ tels|join('/') }}</div>{% endif %}
                <div class="date">{{ (courrier.createdAt|default(null) ? courrier.createdAt : "now")|date("d/m/Y") }}</div>
            </td>
        </tr>
    </table>

    {# ── Titre ── #}
    <div class="title">REÇU COURRIER</div>

    {% if courrier.statut in ['PERDU', 'ANNULE'] %}
    <div class="statut-banner">{{ courrier.statut == 'PERDU' ? 'COURRIER PERDU' : 'COURRIER ANNULÉ' }}</div>
    {% endif %}

    {# ── Destination ── #}
    <div class="line">DESTINATION :<span class="v">{{ garearrivee ? garearrivee.libelle|upper : '—' }}</span></div>

    {# ── Valeur + Frais ── #}
    {% set valeur = courrier.detailcourriers|map(d => d.valeur)|reduce((carry, v) => carry + v, 0) %}
    <table class="vf">
        <tr>
            <td>VALEUR : {{ valeur|number_format(0, ',', ' ') }}</td>
            <td>FRAIS : <span class="big">{{ courrier.montant|number_format(0, ',', ' ') }}</span></td>
        </tr>
    </table>

    {# ── Code ── #}
    <div class="code"><span class="lbl">CODE :</span> {{ courrier.codecourrier }}</div>

    {# ── Expéditeur ── #}
    <div class="sect">EXPÉDITEUR</div>
    <div class="sect-v">{{ courrier.nomexpediteur|upper }}</div>
    <div class="sect-c">{{ courrier.contactexpediteur }}</div>

    {# ── Destinataire ── #}
    <div class="sect">DESTINATAIRE</div>
    <div class="sect-v">{{ courrier.nomdestinataire|upper }}</div>
    <div class="sect-c">{{ courrier.contactdestinataire }}</div>

    {# ── Référence ── #}
    {% if courrier.voyage %}
    <div class="ref">RÉF : {{ courrier.voyage.codevoyage }}</div>
    {% endif %}

    {# ── Frais de suivi SMS ── #}
    {% if courrier.fraissuivi %}
    <div class="suivi">FRAIS DE SUIVI SMS :<span class="big">{{ courrier.fraissuivi|number_format(0, ',', ' ') }}</span></div>
    {% endif %}

    {# ── Liste des colis ── #}
    <div class="table-title">LISTE DES COLIS</div>
    <table class="colis">
        <thead>
            <tr>
                <th>NATURE</th>
                <th>DÉSIGNATION</th>
            </tr>
        </thead>
        <tbody>
            {% for detail in courrier.detailcourriers %}
            <tr>
                <td>{{ detail.nature|upper }}</td>
                <td>{{ detail.designation|upper }}</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>

    {# ── Pied ── #}
    <div class="footer">
        <p>NB : PASSÉ UN DÉLAI DE 15 JOURS {{ marque|upper }} PAS RESPONSABLE EN CAS DE PERTE</p>
        <p>PAS DE REMBOURSEMENT APRÈS ENCAISSEMENT</p>
    </div>

</body>
</html>
