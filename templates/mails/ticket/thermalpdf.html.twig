<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <style>
        @page { margin: 0; }
        * { margin: 0; padding: 0; }

        html, body {
            font-family: "DejaVu Sans", sans-serif;
            font-size: 11px;
            line-height: 1.35;
            color: #000;
            background: #fff;
        }

        /* Conteneur AUTO-largeur (SANS width:100%) : sous Dompdf, un bloc sans
           largeur explicite remplit la page et son padding décale le contenu des
           DEUX côtés sans déborder — alors que width:100% + padding déborde à droite. */
        .ticket { padding: 9px 11px; }
        .ticket-break { page-break-after: always; }
        .c { text-align: center; }

        /* ── En-tête : sigle (gauche) / émission + gare émettrice (droite) ── */
        .head { width: 100%; border-collapse: collapse; }
        .head td { vertical-align: top; }
        .head .hl { text-align: left; }
        .head .hr { text-align: right; font-size: 9px; line-height: 1.35; }
        .sigle { font-size: 20px; font-weight: bold; letter-spacing: 1px; }
        .sigle-line { border-bottom: 2px dotted #000; width: 74px; height: 4px; margin-top: 2px; }
        .gare-emet { font-weight: bold; }

        /* ── Bandeau statut (annulé / reporté) ── */
        .banner { background: #000; color: #fff; text-align: center; font-weight: bold;
                  text-transform: uppercase; letter-spacing: 2px; font-size: 12px; padding: 3px; margin: 5px 0; }

        /* ── Séparateur pointillé ── */
        .sep { border-top: 1px dashed #999; margin: 6px 0; }

        /* ── Corps ── */
        .ticketno { font-size: 11px; margin-top: 5px; }
        .depart { font-size: 13px; font-weight: bold; margin-top: 3px; }
        .vlabel { font-size: 10px; letter-spacing: 2px; margin-top: 6px; }
        .route { font-size: 15px; font-weight: bold; line-height: 1.25; margin: 2px 0 4px; }

        /* ── Grille VOYAGE / SIÈGE : 3 cellules (case | espace | case),
           border-collapse pour une largeur EXACTE de 100 % (aucun débordement). ── */
        .grid { width: 100%; border-collapse: collapse; margin: 6px 0; }
        .grid .box { width: 46%; text-align: center; border: 1px dashed #000; padding: 5px 2px; }
        .grid .gap { width: 8%; border: 0; }
        .grid .k { font-size: 9px; letter-spacing: 1px; display: block; }
        .grid .v { font-size: 20px; font-weight: bold; display: block; margin-top: 1px; }
        .grid .code { font-size: 15px; font-weight: bold; display: block; margin-top: 3px; }

        .tarif { font-size: 14px; font-weight: bold; margin-top: 5px; }
        .vehicule { font-size: 11px; margin-top: 3px; }
        .nb { font-style: italic; font-size: 10px; margin-top: 6px; }

        /* ── Zone QR ── */
        .qr { text-align: center; margin-top: 8px; }
        .qr img { width: 70px; height: 70px; }
        .qr-cap { font-size: 9px; font-weight: bold; margin-top: 3px; }

        /* ── Pied ── */
        .wish { font-size: 10px; margin-top: 7px; }
        .phones { font-size: 10px; font-weight: bold; margin-top: 1px; }
        .editor { font-size: 8px; color: #555; margin-top: 4px; }

        /* ── Perforation (détachement de la souche) ── */
        .perf { border-top: 1px dashed #000; margin: 12px 0 8px; }

        /* ── Souche (talon condensé) ── */
        .s-sigle { font-size: 15px; font-weight: bold; }
        .s-line { border-bottom: 2px dotted #000; width: 54px; height: 3px; margin-top: 2px; }
        .s-row { font-size: 10px; margin-top: 2px; }
        .s-route { font-size: 11px; font-weight: bold; margin-top: 3px; }
        .s-grid { width: 100%; border-collapse: collapse; margin: 4px 0; }
        .s-grid .box { width: 46%; text-align: center; border: 1px dashed #000; padding: 3px 2px; font-size: 11px; }
        .s-grid .gap { width: 8%; border: 0; }
        .s-grid b { font-size: 12px; }
    </style>
</head>
<body>

    {% set items = tickets is defined ? tickets : [ticket] %}
    {% set ent = entreprise|default(null) %}
    {% set company = ent.libelle|default('Compagnie de transport') %}
    {% set sigle = (ent.sigle is defined and ent.sigle) ? ent.sigle : company|slice(0, 4)|upper %}
    {% set phones = [ent.contact1 ?? null, ent.contact2 ?? null]|filter(p => p)|join(' / ') %}

    {% for ticket in items %}
    {% set montee = ticket.gare.libelle ?? ticket.voyage.provenance %}
    {% set descente = ticket.garedescente.libelle ?? ticket.voyage.destination %}
    {% set tarif = (ticket.prix + (ticket.remise ?? 0))|number_format(0, ',', ' ') %}
    {% set codevoyage = ticket.voyage.codevoyage ?? '—' %}
    {% set seat = ticket.siege.numero ?? '—' %}
    {% set vehicule = ticket.vehicule ?? '—' %}
    {% set depart = ticket.voyage.datedepartprevue ? ticket.voyage.datedepartprevue|date('d/m/Y - H:i') : '—' %}
    {% set emisle = ticket.createdAt ? ticket.createdAt|date('d/m/Y - H:i:s') : '' %}

    <div class="ticket {{ loop.last ? '' : 'ticket-break' }}">

        {# ══ BILLET ══ #}
        <table class="head">
            <tr>
                <td class="hl">
                    <div class="sigle">{{ sigle }}</div>
                    <div class="sigle-line"></div>
                </td>
                <td class="hr">
                    <div>{{ emisle }}</div>
                    <div class="gare-emet">{{ montee }}</div>
                </td>
            </tr>
        </table>

        {% if ticket.statut is defined and ticket.statut in ['ANNULE', 'REPORTE'] %}
        <div class="banner">{{ ticket.statut == 'ANNULE' ? 'Billet annulé' : 'Billet reporté' }}</div>
        {% endif %}

        <div class="c ticketno">Ticket n&deg; : {{ ticket.codeticket }}</div>
        <div class="c depart">Départ : {{ depart }}</div>

        <div class="c vlabel">VOYAGE</div>
        <div class="c route">{{ montee }}<br>{{ descente }}</div>

        <table class="grid">
            <tr>
                <td class="box"><span class="k">VOYAGE</span><span class="code">{{ codevoyage }}</span></td>
                <td class="gap"></td>
                <td class="box"><span class="k">SIÈGE</span><span class="v">{{ seat }}</span></td>
            </tr>
        </table>

        <div class="c tarif">TARIF : {{ tarif }} FCFA</div>
        <div class="c vehicule">Véhicule : {{ vehicule }}</div>

        <div class="sep"></div>
        <div class="c nb">NB : Le ticket n'est pas remboursable</div>

        {% if ticket.qrcode is defined and ticket.qrcode %}
        <div class="qr">
            <img src="{{ ticket.qrcode }}" alt="">
            <div class="qr-cap">Présentez ce billet à l'embarquement</div>
        </div>
        {% endif %}

        <div class="sep"></div>
        <div class="c wish">{{ company }} vous souhaite un agréable voyage</div>
        {% if phones %}<div class="c phones">{{ phones }}</div>{% endif %}
        <div class="c editor">Édité par iTransport</div>

        {# ══ SOUCHE (talon détachable) ══ #}
        <div class="perf"></div>

        <table class="head">
            <tr>
                <td class="hl">
                    <div class="s-sigle">{{ sigle }}</div>
                    <div class="s-line"></div>
                </td>
                <td class="hr">
                    <div>{{ emisle }}</div>
                    <div class="gare-emet">{{ montee }}</div>
                </td>
            </tr>
        </table>
        <div class="c s-row">Ticket n&deg; : {{ ticket.codeticket }}</div>
        <div class="c s-row">Départ : {{ depart }}</div>
        <div class="c s-route">{{ montee }} &#8211; {{ descente }}</div>
        <table class="s-grid">
            <tr>
                <td class="box">VOYAGE <b>{{ codevoyage }}</b></td>
                <td class="gap"></td>
                <td class="box">SIÈGE <b>{{ seat }}</b></td>
            </tr>
        </table>
        <div class="c s-row">Tarif : {{ tarif }} FCFA</div>
        <div class="c s-row">Véhicule : {{ vehicule }}</div>

    </div>
    {% endfor %}

</body>
</html>
