{% extends 'base.html.twig' %}

{% block title %}Bordereaux{% endblock %}

{% block body %}

{# ── En-tête ─────────────────────────────────────────────────────── #}
<div class="mb-6 flex items-start gap-3.5">
    <div class="flex size-12 shrink-0 items-center justify-center rounded-2xl bg-blue-50 text-blue-600 dark:bg-blue-950/60 dark:text-blue-400">
        <svg class="size-6" fill="none" stroke="currentColor" stroke-width="1.6" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 3.75h6M9 8.25h6M5.25 5.25h13.5A1.5 1.5 0 0 1 20.25 6.75v12.75A1.5 1.5 0 0 1 18.75 21H5.25a1.5 1.5 0 0 1-1.5-1.5V6.75a1.5 1.5 0 0 1 1.5-1.5Z"/></svg>
    </div>
    <div>
        <p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-blue-600 mb-1">Exploitation</p>
        <h1 class="text-4xl font-light tracking-[-0.55px] leading-[1.1]">Bordereaux</h1>
        <p class="text-muted-foreground mt-2 text-sm">Choisissez une ligne et une période, puis imprimez le bordereau de gare ou le bordereau chauffeur d'un voyage.</p>
    </div>
</div>

{# ── Filtres ─────────────────────────────────────────────────────── #}
{% set aFiltre = ligneId or gareId %}
<form method="get" action="{{ path('bordereau.index') }}" class="card mb-6 overflow-hidden p-0">
    <div class="flex items-center gap-2 border-b bg-muted/30 px-5 py-3">
        <svg class="size-4 text-muted-foreground" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3c2.755 0 5.455.232 8.083.678.533.09.917.556.917 1.096v1.044a2.25 2.25 0 0 1-.659 1.591l-5.432 5.432a2.25 2.25 0 0 0-.659 1.591v2.927a2.25 2.25 0 0 1-1.244 2.013L9.75 21v-6.568a2.25 2.25 0 0 0-.659-1.591L3.659 7.409A2.25 2.25 0 0 1 3 5.818V4.774c0-.54.384-1.006.917-1.096A48.32 48.32 0 0 1 12 3Z"/></svg>
        <span class="text-sm font-medium">Filtres</span>
        {% if aFiltre %}
        <a href="{{ path('bordereau.index') }}" class="ml-auto inline-flex items-center gap-1 text-xs font-medium text-muted-foreground hover:text-foreground transition">
            <svg class="size-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.53 2.47a.75.75 0 0 1 0 1.06L4.81 8.25H15a6.75 6.75 0 0 1 0 13.5h-3a.75.75 0 0 1 0-1.5h3a5.25 5.25 0 1 0 0-10.5H4.81l4.72 4.72a.75.75 0 1 1-1.06 1.06l-6-6a.75.75 0 0 1 0-1.06l6-6a.75.75 0 0 1 1.06 0Z"/></svg>
            Réinitialiser
        </a>
        {% endif %}
    </div>

    <div class="p-5">
        <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-4">
            {# Ligne #}
            <div class="flex flex-col gap-1.5">
                <label class="flex items-center gap-1.5 text-xs font-medium text-muted-foreground">
                    <svg class="size-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498 4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 0 0-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0Z"/></svg>
                    Ligne
                </label>
                {# Autocomplete distant (tom-select → /search?resource=lignes) au lieu de charger toutes les lignes.
                   NB : pas de classe .input ici — tom-select stylise son propre wrapper (.ts-wrapper), sinon superposition. #}
                <select name="ligne"
                        data-remote-select="lignes"
                        placeholder="Choisir une ligne…"
                        {% if ligneId %}data-value="{{ ligneId }}" data-label="{{ selectedLigneLabel }}"{% endif %}></select>
            </div>

            {# Gare #}
            <div class="flex flex-col gap-1.5">
                <label class="flex items-center gap-1.5 text-xs font-medium text-muted-foreground">
                    <svg class="size-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21"/></svg>
                    Gare
                </label>
                {% if userGareId %}
                    {# Agent rattaché à une gare : gare forcée à la sienne #}
                    <div class="flex h-9 items-center rounded-md border bg-muted/50 px-3 text-sm text-muted-foreground cursor-not-allowed">
                        <span class="truncate">{{ userGareLibelle }}</span>
                        <span class="ml-1.5 shrink-0 rounded bg-background/70 px-1.5 py-0.5 text-[10px] font-medium">votre gare</span>
                    </div>
                    <input type="hidden" name="gare" value="{{ userGareId }}" />
                {% else %}
                    <select name="gare" class="input input-sm w-full">
                        <option value="">Toutes les gares…</option>
                        {% for g in gares %}
                        <option value="{{ g.id }}" {{ gareId == g.id ? 'selected' : '' }}>
                            {{ g.libelle }} — {{ g.ville }}
                        </option>
                        {% endfor %}
                    </select>
                {% endif %}
            </div>

            {# Période #}
            <div class="flex flex-col gap-1.5 md:col-span-2">
                <label class="flex items-center gap-1.5 text-xs font-medium text-muted-foreground">
                    <svg class="size-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5"/></svg>
                    Période
                </label>
                <div class="flex items-center gap-1.5 rounded-lg border bg-background px-2 focus-within:ring-1 focus-within:ring-blue-500 transition">
                    <input type="date" name="debut" value="{{ debut }}" aria-label="Date de début" class="input input-sm w-full min-w-0 border-0 bg-transparent shadow-none focus:ring-0" />
                    <span class="shrink-0 text-sm text-muted-foreground">→</span>
                    <input type="date" name="fin" value="{{ fin }}" aria-label="Date de fin" class="input input-sm w-full min-w-0 border-0 bg-transparent shadow-none focus:ring-0" />
                </div>
            </div>
        </div>

        <div class="mt-4 flex items-center justify-end gap-3">
            {% if aFiltre %}
            <a href="{{ path('bordereau.index') }}" class="text-sm font-medium text-muted-foreground hover:text-foreground transition max-sm:hidden">Réinitialiser</a>
            {% endif %}
            <button type="submit" class="inline-flex items-center gap-1.5 rounded-lg bg-blue-600 px-5 py-2 text-sm font-medium text-white hover:bg-blue-700 transition max-sm:w-full max-sm:justify-center">
                <svg class="size-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M17 11a6 6 0 11-12 0 6 6 0 0112 0z" /></svg>
                Rechercher
            </button>
        </div>
    </div>
</form>

{# ── Résultats ───────────────────────────────────────────────────── #}
{% if not ligneId %}
    <div class="card p-10 text-center">
        <p class="text-sm text-muted-foreground">Sélectionnez une ligne pour afficher les voyages disponibles.</p>
    </div>

{% elseif voyages is empty %}
    <div class="card p-10 text-center">
        <p class="text-sm text-muted-foreground">Aucun voyage trouvé pour cette ligne sur la période sélectionnée.</p>
    </div>

{% else %}
    {% if not gareId %}
    <div class="mb-4 flex items-start gap-2 rounded-lg border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-700 dark:border-amber-900 dark:bg-amber-950/40 dark:text-amber-300">
        <svg class="mt-0.5 size-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m0 3.75h.008M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        Sélectionnez une gare pour pouvoir imprimer le bordereau de gare.
    </div>
    {% endif %}

    <div class="card overflow-hidden">
        <table class="w-full text-sm">
            <thead>
                <tr class="text-left text-muted-foreground border-b bg-muted/30">
                    <th class="px-4 py-3 font-medium">Voyage</th>
                    <th class="px-4 py-3 font-medium">Itinéraire</th>
                    <th class="px-4 py-3 font-medium">Départ</th>
                    <th class="px-4 py-3 font-medium text-right">Places</th>
                    <th class="px-4 py-3 font-medium text-right">Vendus</th>
                    <th class="px-4 py-3 font-medium text-center">Statut</th>
                    <th class="px-4 py-3 font-medium text-right">Bordereaux</th>
                </tr>
            </thead>
            <tbody>
                {% for v in voyages %}
                {% set termine = v.datearriveereelle is defined and v.datearriveereelle is not null %}
                <tr class="border-b last:border-0 hover:bg-muted/40 transition-colors">
                    <td class="px-4 py-3 font-mono text-xs">{{ v.codevoyage }}</td>
                    <td class="px-4 py-3">{{ v.provenance }} → {{ v.destination }}</td>
                    <td class="px-4 py-3 text-muted-foreground tabular-nums">{{ v.datedepartprevue | date('d/m/Y H:i') }}</td>
                    <td class="px-4 py-3 text-right tabular-nums">{{ v.placestotal }}</td>
                    <td class="px-4 py-3 text-right tabular-nums">{{ v.ticketsCount }}</td>
                    <td class="px-4 py-3 text-center">
                        <span class="text-xs px-2 py-0.5 rounded-full
                            {{ termine ? 'bg-green-100 text-green-700 dark:bg-green-950 dark:text-green-300' : 'bg-blue-100 text-blue-700 dark:bg-blue-950 dark:text-blue-300' }}">
                            {{ termine ? 'Terminé' : 'En cours' }}
                        </span>
                    </td>
                    <td class="px-4 py-3">
                        <div class="flex items-center justify-end gap-2">
                            {% if gareId %}
                            <a href="{{ path('bordereau.print', {voyageId: v.id, gareId: gareId}) }}" target="_blank"
                               class="inline-flex items-center gap-1 rounded-md border px-2.5 py-1 text-xs font-medium hover:bg-muted transition">
                                <svg class="size-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6.72 13.829c-.24.03-.48.062-.72.096m.72-.096a42.415 42.415 0 0110.56 0m-10.56 0L6.34 18m10.94-4.171c.24.03.48.062.72.096m-.72-.096L17.66 18m0 0l.229 2.523a1.125 1.125 0 01-1.12 1.227H7.231c-.662 0-1.18-.568-1.12-1.227L6.34 18m11.318 0h1.091A2.25 2.25 0 0021 15.75V9.456c0-1.081-.768-2.015-1.837-2.175a48.055 48.055 0 00-1.913-.247M6.34 18H5.25A2.25 2.25 0 013 15.75V9.456c0-1.081.768-2.015 1.837-2.175a48.041 48.041 0 011.913-.247m10.5 0a48.536 48.536 0 00-10.5 0m10.5 0V3.375c0-.621-.504-1.125-1.125-1.125h-8.25c-.621 0-1.125.504-1.125 1.125v3.659M18 10.5h.008v.008H18V10.5zm-3 0h.008v.008H15V10.5z" /></svg>
                                Gare
                            </a>
                            {% endif %}
                            <a href="{{ path('bordereau.chauffeur', {voyageId: v.id}) }}" target="_blank"
                               class="inline-flex items-center gap-1 rounded-md border px-2.5 py-1 text-xs font-medium hover:bg-muted transition">
                                <svg class="size-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" /></svg>
                                Chauffeur
                            </a>
                        </div>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endif %}
{% endblock %}
