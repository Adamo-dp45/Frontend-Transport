{% extends 'base.html.twig' %}
{% import 'components/detail.html.twig' as ui %}

{% block title %}Profil{% endblock %}

{% set roleTones = { ROLE_SUPER_ADMIN: 'purple', ROLE_ADMIN: 'red', ROLE_USER: 'zinc', ROLE_ADMIN_GARE: 'blue' } %}
{% set roleLabels = { ROLE_SUPER_ADMIN: 'Super Admin', ROLE_ADMIN: 'Admin', ROLE_USER: 'Utilisateur', ROLE_ADMIN_GARE: 'Admin de gare' } %}

{% block body %}
<div class="mb-6">
    <p class="text-xs uppercase tracking-wide text-muted-foreground mb-0.5">Mon compte</p>
    <h1 class="text-3xl font-light tracking-[-0.5px] leading-[1.2]">Mon profil</h1>
    <p class="text-sm text-muted-foreground mt-1">Gérer vos informations personnelles et votre sécurité</p>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    {# ── Colonne gauche : avatar + accès ── #}
    <div class="space-y-4">
        <div class="card p-6 flex flex-col items-center gap-4">
            <div class="relative">
                {% if app.user.fileUrl is defined and app.user.fileUrl %}
                <img src="{{ api_url ~ '/media' ~ app.user.fileUrl ~ '?w=400&h=400&fm=jpg&fit=crop' }}" alt="Avatar" class="w-24 h-24 rounded-full object-cover ring-4 ring-primary/10" />
                {% else %}
                <div class="w-24 h-24 rounded-full bg-primary/10 flex items-center justify-center ring-4 ring-primary/10">
                    <span class="text-3xl font-semibold text-primary">{{ app.user.prenom|upper|slice(0,1) }}{{ app.user.nom|upper|slice(0,1) }}</span>
                </div>
                {% endif %}
            </div>
            <div class="text-center">
                <p class="font-medium text-lg">{{ app.user.prenom }} {{ app.user.nom }}</p>
                <p class="text-muted-foreground text-sm break-all">{{ app.user.email }}</p>
                {% if app.user.gare %}<p class="text-xs text-muted-foreground mt-1">🏪 {{ app.user.gare.libelle }}</p>{% endif %}
            </div>

            {# Upload avatar (préservé) #}
            <form method="POST" action="{{ path('profile.avatar') }}" enctype="multipart/form-data" id="form-avatar" class="w-full">
                <label for="avatar-input" class="flex w-full cursor-pointer items-center justify-center gap-1.5 rounded-md border border-border px-3 py-2 text-sm font-medium hover:bg-muted transition-colors">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
                    Changer l'avatar
                </label>
                <input type="file" id="avatar-input" name="avatar" accept="image/jpeg,image/png,image/webp,image/gif" class="hidden" onchange="document.getElementById('form-avatar').requestSubmit()" />
                <p class="text-xs text-muted-foreground text-center mt-1.5">JPG, PNG, WEBP · max 2 Mo</p>
            </form>
        </div>

        <div class="card p-5">
            <h2 class="text-sm font-semibold uppercase tracking-wide text-muted-foreground mb-3">Accès</h2>
            <div class="flex flex-wrap gap-1.5">
                {% for role in app.user.roles %}{{ ui.badge(roleLabels[role] ?? role, roleTones[role] ?? 'zinc') }}{% endfor %}
            </div>
            {% if app.user.userRoles is defined and app.user.userRoles|length > 0 %}
            <div class="pt-3 mt-3 border-t border-border">
                <p class="text-xs text-muted-foreground mb-2">Rôles métier</p>
                <div class="flex flex-wrap gap-1.5">
                    {% for ur in app.user.userRoles %}{{ ui.badge(ur.role.name, 'blue') }}{% endfor %}
                </div>
            </div>
            {% endif %}
        </div>
    </div>

    {# ── Colonne droite : infos + sécurité ── #}
    <div class="lg:col-span-2 space-y-4">
        <div class="card p-6">
            <div class="flex items-center justify-between gap-3 mb-4">
                <h2 class="text-sm font-semibold uppercase tracking-wide text-muted-foreground">Informations personnelles</h2>
                <a href="{{ path('profile.edit') }}" class="inline-flex items-center gap-1 text-xs text-primary hover:underline shrink-0">
                    <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                    Modifier
                </a>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-4">
                {{ ui.field('Nom', app.user.nom) }}
                {{ ui.field('Prénom', app.user.prenom) }}
                {{ ui.field('Email', '<a href="mailto:' ~ app.user.email ~ '" class="text-primary hover:underline">' ~ app.user.email ~ '</a>', false, true) }}
                {% if app.user.gare %}{{ ui.field('Gare', app.user.gare.libelle) }}{% endif %}
            </div>
        </div>

        <div class="card p-6">
            <h2 class="text-sm font-semibold uppercase tracking-wide text-muted-foreground mb-4">Sécurité</h2>
            <div class="flex items-center justify-between gap-4 rounded-lg border border-border px-4 py-3">
                <div class="min-w-0">
                    <p class="text-sm font-medium">Mot de passe</p>
                    <p class="text-xs text-muted-foreground mt-0.5">Modifiez votre mot de passe de connexion</p>
                </div>
                <a href="{{ path('profile.password') }}" class="btn btn-primary shrink-0">Changer</a>
            </div>
        </div>

        {# ── Zone de danger : suppression de compte (= suspension) ── #}
        {% if not is_granted('ROLE_SUPER_ADMIN') %}
        <div class="card border-rose-200 p-6 dark:border-rose-900">
            <h2 class="mb-4 text-sm font-semibold uppercase tracking-wide text-rose-600 dark:text-rose-400">Zone de danger</h2>
            <div class="flex flex-col gap-3 rounded-lg border border-rose-200 bg-rose-50/50 px-4 py-3 dark:border-rose-900 dark:bg-rose-950/20 sm:flex-row sm:items-center sm:justify-between">
                <div class="min-w-0">
                    <p class="text-sm font-medium">Supprimer mon compte</p>
                    <p class="mt-0.5 text-xs text-muted-foreground">Votre compte sera désactivé et vous serez déconnecté. Un administrateur pourra le réactiver.</p>
                </div>
                <button type="button" class="btn btn-danger shrink-0" onclick="document.getElementById('dlg-delete-account').showModal()">
                    Supprimer
                </button>
            </div>
        </div>
        {% endif %}
    </div>
</div>

{# ── Modal de confirmation par mot de passe ── #}
{% if not is_granted('ROLE_SUPER_ADMIN') %}
<dialog id="dlg-delete-account" class="m-auto w-[92vw] max-w-md rounded-xl border bg-card p-0 text-foreground shadow-2xl backdrop:bg-black/50">
    <form method="POST" action="{{ path('profile.delete') }}" data-turbo="false">
        <div class="p-5">
            <div class="mb-3 flex items-start gap-3">
                <div class="flex size-10 shrink-0 items-center justify-center rounded-full bg-rose-100 text-rose-600 dark:bg-rose-950 dark:text-rose-400">
                    <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3z"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>
                </div>
                <div>
                    <h3 class="text-base font-semibold">Supprimer mon compte</h3>
                    <p class="mt-0.5 text-sm text-muted-foreground">Cette action <strong>désactive votre compte</strong> et vous déconnecte immédiatement. Saisissez votre mot de passe pour confirmer.</p>
                </div>
            </div>
            <label class="label" for="delete-password">Mot de passe</label>
            <input type="password" id="delete-password" name="password" class="input" placeholder="Votre mot de passe" required autocomplete="current-password" />
            <input type="hidden" name="_token" value="{{ csrf_token('delete_account') }}" />
        </div>
        <div class="flex justify-end gap-2 border-t px-5 py-3">
            <button type="button" class="btn btn-secondary" onclick="this.closest('dialog').close()">Annuler</button>
            <button type="submit" class="btn btn-danger">Confirmer la suppression</button>
        </div>
    </form>
</dialog>
{% endif %}
{% endblock %}
