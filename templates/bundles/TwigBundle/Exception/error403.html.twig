{% extends 'bundles/TwigBundle/Exception/_error_layout.html.twig' %}

{% block heading %}Accès interdit{% endblock %}
{% block badge %}Accès refusé{% endblock %}
{% block dot %}bg-amber-500{% endblock %}
{% block code %}403{% endblock %}
{% block description %}
    Vous n'avez pas les permissions nécessaires pour accéder à cette page. Si vous pensez qu'il s'agit d'une erreur, contactez votre administrateur.
{% endblock %}
{% block icon %}
<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
{% endblock %}
{% block actions %}
<a href="{{ path('home') }}" class="btn btn-primary w-full justify-center">
    <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><path stroke-linecap="round" stroke-linejoin="round" d="M9 22V12h6v10"/></svg>
    Retour à l'accueil
</a>
<a href="javascript:history.back()" class="btn btn-secondary w-full justify-center">Page précédente</a>
{% endblock %}
