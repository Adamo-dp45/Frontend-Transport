{% extends 'base.html.twig' %}
{% import 'home/_stats.html.twig' as s %}

{% block title %}Lignes{% endblock %}

{% block body %}
{{ s.pageHeader('Performance par ligne', 'Exploitation', 'owner.trajets', debut, fin, 'stats.export.trajet') }}

{% set perfs = lignes.performances ?? [] %}
{% set plusActive = perfs|length > 0 ? (perfs[0].libelle ?? perfs[0].codeligne) : '—' %}
{% set derniere = perfs|last %}
{% set moinsActive = (derniere is defined and derniere and derniere.nbvoyages == 0) ? (derniere.libelle ?? derniere.codeligne) : '—' %}

<section class="mb-10">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 mb-8">
        {{ s.kpi('Total lignes', lignes.totalLignes, '', 'blue', 'route') }}
        {{ s.kpi('Ligne la plus active', plusActive, '', 'emerald', 'check') }}
        {{ s.kpi('Ligne la moins active', moinsActive, '', 'amber', 'alert') }}
    </div>

    {# ── Recette par ligne (redesign) ────────────────────────────────── #}
    {% set maxRec = perfs|length > 0 ? perfs[0].recette : 0 %}
    {% set totalRec = perfs|reduce((c, l) => c + l.recette, 0) %}

    <div class="flex items-end justify-between mb-4">
        <h2 class="text-lg font-medium">Recette par ligne</h2>
        <span class="text-xs text-muted-foreground">Billets + réservations · courriers · bagages</span>
    </div>

    {% if perfs|length == 0 %}
    <div class="card p-10 text-center text-sm text-muted-foreground">Aucune ligne active sur la période.</div>
    {% else %}
    <div class="space-y-3">
        {% for l in perfs %}
        {% set share = totalRec > 0 ? (l.recette / totalRec * 100) : 0 %}
        {% set barW = maxRec > 0 ? (l.recette / maxRec * 100) : 0 %}
        <div class="card p-5">
            <div class="flex items-baseline justify-between gap-3 mb-2">
                <div class="flex items-baseline gap-2.5 min-w-0">
                    <span class="text-sm font-mono text-muted-foreground shrink-0">#{{ loop.index }}</span>
                    <div class="min-w-0">
                        <h3 class="font-medium truncate leading-tight">{{ l.libelle ?? l.codeligne }}</h3>
                        <p class="text-xs text-muted-foreground">{{ l.codeligne }} · {{ l.nbvoyages }} voyage{{ l.nbvoyages > 1 ? 's' : '' }}</p>
                    </div>
                </div>
                <div class="text-right shrink-0">
                    <p class="text-xl font-semibold tabular-nums">{{ l.recette|number_format(0, ',', ' ') }} <span class="text-xs font-normal text-muted-foreground">F</span></p>
                    <p class="text-xs text-muted-foreground">{{ share|round }} % du total</p>
                </div>
            </div>

            <div class="h-2 w-full rounded-full bg-muted overflow-hidden mb-4">
                <div class="h-2 rounded-full bg-emerald-500" style="width: {{ barW }}%"></div>
            </div>

            <div class="grid grid-cols-3 gap-2">
                <div class="rounded-lg border border-blue-100 dark:border-blue-950 bg-blue-50/50 dark:bg-blue-950/30 p-2.5">
                    <div class="flex items-center gap-1.5 mb-0.5">
                        <span class="size-2 rounded-full bg-blue-500"></span>
                        <span class="text-[11px] text-muted-foreground">Billets + résa · {{ l.nbtickets }}</span>
                    </div>
                    <p class="text-sm font-semibold tabular-nums">{{ l.recetteBillets|number_format(0, ',', ' ') }} <span class="text-[11px] font-normal text-muted-foreground">F</span></p>
                </div>
                <div class="rounded-lg border border-amber-100 dark:border-amber-950 bg-amber-50/50 dark:bg-amber-950/30 p-2.5">
                    <div class="flex items-center gap-1.5 mb-0.5">
                        <span class="size-2 rounded-full bg-amber-500"></span>
                        <span class="text-[11px] text-muted-foreground">Courriers · {{ l.nbcourriers }}</span>
                    </div>
                    <p class="text-sm font-semibold tabular-nums">{{ l.recetteCourriers|number_format(0, ',', ' ') }} <span class="text-[11px] font-normal text-muted-foreground">F</span></p>
                </div>
                <div class="rounded-lg border border-emerald-100 dark:border-emerald-950 bg-emerald-50/50 dark:bg-emerald-950/30 p-2.5">
                    <div class="flex items-center gap-1.5 mb-0.5">
                        <span class="size-2 rounded-full bg-emerald-500"></span>
                        <span class="text-[11px] text-muted-foreground">Bagages · {{ l.nbbagages }}</span>
                    </div>
                    <p class="text-sm font-semibold tabular-nums">{{ l.recetteBagages|number_format(0, ',', ' ') }} <span class="text-[11px] font-normal text-muted-foreground">F</span></p>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
    {% endif %}
</section>
{% endblock %}
