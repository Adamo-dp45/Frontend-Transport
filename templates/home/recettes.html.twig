{% extends 'base.html.twig' %}
{% import 'home/_stats.html.twig' as s %}

{% block title %}Recettes{% endblock %}

{% block body %}
{{ s.pageHeader('Recettes', 'Synthèse', 'owner.recettes', debut, fin) }}

{% set total = financiere.recettesTotales ?? 0 %}
{% set rR = financiere.recettesReservations ?? 0 %}
{% set ventesBillets = (financiere.recettesTickets ?? 0) + rR %}

{# ── Vue d'ensemble ──────────────────────────────────────────────── #}
<section class="mb-10">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3 mb-3">
        {# Recette totale — carte vedette #}
        <div class="relative overflow-hidden rounded-xl bg-gradient-to-br from-emerald-600 to-emerald-700 p-5 text-white shadow-sm lg:col-span-2">
            <svg class="absolute -right-4 -bottom-4 size-28 text-white/10" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" />
            </svg>
            <div class="relative">
                <p class="text-[11px] font-medium uppercase tracking-wider text-emerald-100 mb-1.5">Recette totale</p>
                <p class="text-3xl font-semibold tracking-tight leading-none">{{ total|number_format(0, ',', ' ') }}<span class="text-base font-normal text-emerald-100 ml-1">FCFA</span></p>
                <p class="text-xs text-emerald-100/90 mt-3">Billets · réservations · courriers · bagages sur la période</p>
            </div>
        </div>
        {{ s.kpi('Bénéfice net', (financiere.beneficeNet ?? 0)|number_format(0, ',', ' '), 'FCFA', 'violet', 'money', 'Recettes − coûts (dépannages, appro.)', (financiere.beneficeNet ?? 0) < 0 ? 'text-rose-500' : 'text-emerald-600') }}
        {{ s.kpi('Part réservations', ventesBillets > 0 ? (rR / ventesBillets * 100)|round : 0, '%', 'teal', 'chart', 'Des ventes de billets') }}
    </div>

    {# Détail par type #}
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-6">
        <div class="card p-4">
            <p class="text-xs text-muted-foreground mb-1">Billetterie <span class="opacity-70">· directe</span></p>
            <p class="text-lg font-semibold tabular-nums">{{ (financiere.recettesTickets ?? 0)|number_format(0, ',', ' ') }} <span class="text-xs font-normal text-muted-foreground">F</span></p>
        </div>
        <div class="card p-4">
            <p class="text-xs text-muted-foreground mb-1">Réservations <span class="opacity-70">· payées</span></p>
            <p class="text-lg font-semibold tabular-nums">{{ rR|number_format(0, ',', ' ') }} <span class="text-xs font-normal text-muted-foreground">F</span></p>
        </div>
        <div class="card p-4">
            <p class="text-xs text-muted-foreground mb-1">Courriers</p>
            <p class="text-lg font-semibold tabular-nums">{{ (financiere.recettesCourriers ?? 0)|number_format(0, ',', ' ') }} <span class="text-xs font-normal text-muted-foreground">F</span></p>
        </div>
        <div class="card p-4">
            <p class="text-xs text-muted-foreground mb-1">Bagages</p>
            <p class="text-lg font-semibold tabular-nums">{{ (financiere.recettesBagages ?? 0)|number_format(0, ',', ' ') }} <span class="text-xs font-normal text-muted-foreground">F</span></p>
        </div>
    </div>

    {# Recette par jour #}
    <div class="card p-5">
        <p class="text-sm font-medium text-muted-foreground mb-4">Recette par jour</p>
        <canvas id="chartRecettes" height="90" data-values="{{ financiere.recettesParJour | map(r => {label: r.label, montant: r.montant}) | json_encode }}"></canvas>
    </div>
</section>

{# ── Explorer le détail ──────────────────────────────────────────── #}
<section class="mb-4">
    {{ s.sectionTitle('Explorer le détail', 'Chaque axe de recette sur sa page dédiée') }}
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
        {% set links = [
            { route: 'owner.stats.gares',      icon: 'building', tone: 'emerald', title: 'Par gare',    desc: 'Classement, canaux et croisement par agent' },
            { route: 'owner.stats.commercial', icon: 'users',    tone: 'violet',  title: 'Par commercial', desc: 'Ventes à bord : billets + bagages par vendeur' },
            { route: 'owner.stats.departs',    icon: 'route',    tone: 'teal',    title: 'Par départ',   desc: 'Départs complets vs partiels, gare de provenance' },
            { route: 'owner.trajets',          icon: 'route',    tone: 'blue',    title: 'Par ligne',    desc: 'Recette et fréquentation par ligne' },
            { route: 'owner.agent',            icon: 'money',    tone: 'amber',   title: 'Par agent',    desc: 'Encaissements au comptoir par agent' },
            { route: 'owner.billetterie',      icon: 'ticket',   tone: 'rose',    title: 'Billetterie',  desc: 'Canaux, par jour, trajet et véhicule' },
        ] %}
        {% for l in links %}
        <a href="{{ path(l.route) }}" class="card p-4 flex items-start gap-3 hover:border-primary transition-colors group">
            <span class="flex size-9 shrink-0 items-center justify-center rounded-lg
                {{ {'emerald':'bg-emerald-50 text-emerald-600 dark:bg-emerald-950/60 dark:text-emerald-400',
                    'violet':'bg-violet-50 text-violet-600 dark:bg-violet-950/60 dark:text-violet-400',
                    'teal':'bg-teal-50 text-teal-600 dark:bg-teal-950/60 dark:text-teal-400',
                    'blue':'bg-blue-50 text-blue-600 dark:bg-blue-950/60 dark:text-blue-400',
                    'amber':'bg-amber-50 text-amber-600 dark:bg-amber-950/60 dark:text-amber-400',
                    'rose':'bg-rose-50 text-rose-600 dark:bg-rose-950/60 dark:text-rose-400'}[l.tone] }}">
                <svg class="size-5" fill="none" stroke="currentColor" stroke-width="1.6" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="{{ {
                        'building':'M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21',
                        'users':'M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z',
                        'route':'M9 6.75V15m6-6v8.25m.503 3.498l4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 00-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0z',
                        'money':'M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
                        'ticket':'M16.5 6v.75m0 3v.75m0 3v.75m0 3V18m-9-5.25h5.25M7.5 15h3M3.375 5.25c-.621 0-1.125.504-1.125 1.125v3.026a2.999 2.999 0 010 5.198v3.026c0 .621.504 1.125 1.125 1.125h17.25c.621 0 1.125-.504 1.125-1.125v-3.026a2.999 2.999 0 010-5.198V6.375c0-.621-.504-1.125-1.125-1.125H3.375z'
                    }[l.icon] }}" />
                </svg>
            </span>
            <div class="min-w-0">
                <p class="font-medium leading-tight group-hover:text-primary transition-colors">{{ l.title }}</p>
                <p class="text-xs text-muted-foreground mt-0.5">{{ l.desc }}</p>
            </div>
            <svg class="size-4 text-muted-foreground ml-auto shrink-0 group-hover:text-primary transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
        </a>
        {% endfor %}
    </div>
</section>
{% endblock %}
