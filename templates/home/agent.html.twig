{% extends 'base.html.twig' %}
{% import 'home/_stats.html.twig' as s %}

{% block title %}Agents{% endblock %}

{% macro typeBreakdown(nbtickets, recetteTickets, nbcourriers, recetteCourriers, nbbagages, recetteBagages) %}
    <div class="grid grid-cols-3 gap-2">
        <div class="rounded-lg border border-blue-100 dark:border-blue-950 bg-blue-50/50 dark:bg-blue-950/30 p-2">
            <div class="flex items-center gap-1.5 mb-0.5">
                <span class="size-2 rounded-full bg-blue-500"></span>
                <span class="text-[11px] text-muted-foreground">Tickets · {{ nbtickets }}</span>
            </div>
            <p class="text-sm font-semibold tabular-nums">{{ recetteTickets|number_format(0, ',', ' ') }}</p>
        </div>
        <div class="rounded-lg border border-amber-100 dark:border-amber-950 bg-amber-50/50 dark:bg-amber-950/30 p-2">
            <div class="flex items-center gap-1.5 mb-0.5">
                <span class="size-2 rounded-full bg-amber-500"></span>
                <span class="text-[11px] text-muted-foreground">Courriers · {{ nbcourriers }}</span>
            </div>
            <p class="text-sm font-semibold tabular-nums">{{ recetteCourriers|number_format(0, ',', ' ') }}</p>
        </div>
        <div class="rounded-lg border border-emerald-100 dark:border-emerald-950 bg-emerald-50/50 dark:bg-emerald-950/30 p-2">
            <div class="flex items-center gap-1.5 mb-0.5">
                <span class="size-2 rounded-full bg-emerald-500"></span>
                <span class="text-[11px] text-muted-foreground">Bagages · {{ nbbagages }}</span>
            </div>
            <p class="text-sm font-semibold tabular-nums">{{ recetteBagages|number_format(0, ',', ' ') }}</p>
        </div>
    </div>
{% endmacro %}
{% import _self as agentfx %}

{% block body %}
{{ s.pageHeader('Agents', 'Performance', 'owner.agent', debut, fin, 'stats.export.agent', 'owner.recettes', 'Espace recettes') }}

<section class="mb-8">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3 mb-6">
        {{ s.kpi('Total agents', agents.totalAgents, '', 'blue', 'users') }}
        {{ s.kpi('Actifs sur la période', agents.agentsActifs, '', 'emerald', 'check') }}
    </div>

    <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-medium">Recette encaissée par agent</h2>
        <span class="text-xs text-muted-foreground">{{ agents.performances|length }}</span>
    </div>
    <p class="text-xs text-muted-foreground mb-4">Ce que chaque agent a encaissé au comptoir (billets + courriers + bagages). Les ventes à bord (commercial) et les réservations payées en ligne sont comptées ailleurs.</p>

    {% if agents.performances is empty %}
        <div class="card p-6 text-center text-sm text-muted-foreground">Aucune vente d'agent sur la période.</div>
    {% endif %}

    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
    {% for a in agents.performances %}
    <div class="card p-4">
        <div class="flex items-center justify-between mb-3">
            <div class="flex items-center gap-2.5 min-w-0">
                <span class="flex size-9 shrink-0 items-center justify-center rounded-full bg-muted text-xs font-semibold uppercase">
                    {{ a.prenom|slice(0,1) }}{{ a.nom|slice(0,1) }}
                </span>
                <p class="font-medium truncate">{{ a.prenom }} {{ a.nom }}</p>
            </div>
            <span class="shrink-0 font-semibold text-sm tabular-nums">{{ a.recetteTotale | number_format(0, ',', ' ') }} FCFA</span>
        </div>

        {{ agentfx.typeBreakdown(a.nbtickets, a.recetteTickets, a.nbcourriers, a.recetteCourriers, a.nbbagages, a.recetteBagages) }}

        {% if a.detailParVoyage is not empty %}
        <details class="group mt-3">
            <summary class="cursor-pointer list-none text-xs text-muted-foreground hover:text-foreground flex items-center gap-1 select-none">
                <svg class="size-3.5 transition-transform group-open:rotate-90" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
                Détail billetterie par voyage ({{ a.detailParVoyage|length }})
            </summary>
            <table class="w-full text-sm mt-2">
                <thead>
                    <tr class="text-left text-muted-foreground border-b">
                        <th class="pb-2 font-medium">Voyage</th>
                        <th class="pb-2 font-medium">Trajet</th>
                        <th class="pb-2 font-medium text-right">Tickets</th>
                        <th class="pb-2 font-medium text-right">Recette</th>
                    </tr>
                </thead>
                <tbody>
                    {% for v in a.detailParVoyage %}
                    <tr class="border-b last:border-0">
                        <td class="py-1.5 text-muted-foreground text-xs font-mono">{{ v.codevoyage }}</td>
                        <td class="py-1.5">{{ v.provenance }} → {{ v.destination }}</td>
                        <td class="py-1.5 text-right tabular-nums">{{ v.nbtickets }}</td>
                        <td class="py-1.5 text-right tabular-nums">{{ v.recette | number_format(0, ',', ' ') }}</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </details>
        {% endif %}
    </div>
    {% endfor %}
    </div>
</section>

{# ── Actions critiques par agent (traçabilité anti-fraude) ───────────── #}
{% set crit = agents.actionsCritiques ?? [] %}
{% if crit|length > 0 %}
<section class="mb-8">
    <div class="flex items-center justify-between mb-1">
        <h2 class="text-lg font-medium">Actions critiques par agent</h2>
        <span class="text-xs text-muted-foreground">{{ crit|length }}</span>
    </div>
    <p class="text-xs text-muted-foreground mb-4">Traçabilité : taux d'annulation des ventes, annulations et suppressions effectuées (<strong class="text-foreground">T</strong> billets · <strong class="text-foreground">B</strong> bagages · <strong class="text-foreground">C</strong> courriers). Un taux élevé ou des suppressions méritent une revue.</p>
    <div class="card p-0 overflow-x-auto">
        <table class="w-full text-sm">
            <thead>
                <tr class="text-left text-muted-foreground border-b">
                    <th class="p-3 font-medium">Agent</th>
                    <th class="p-3 font-medium text-right">Ventes billets</th>
                    <th class="p-3 font-medium text-right">Taux annul.</th>
                    <th class="p-3 font-medium text-center">Annulations (T/B/C)</th>
                    <th class="p-3 font-medium text-center">Suppressions (T/B/C)</th>
                </tr>
            </thead>
            <tbody>
                {% for c in crit %}
                {% set totalSuppr = c.supprTickets + c.supprBagages + c.supprCourriers %}
                <tr class="border-b last:border-0 {{ totalSuppr > 0 ? 'bg-red-500/5' : '' }}">
                    <td class="p-3 font-medium">{{ c.prenom }} {{ c.nom }}</td>
                    <td class="p-3 text-right tabular-nums">{{ c.ventesBillets }}</td>
                    <td class="p-3 text-right tabular-nums {{ c.tauxAnnulation >= 20 ? 'text-red-600 dark:text-red-400 font-semibold' : '' }}">
                        {{ c.tauxAnnulation }} %
                        <span class="block text-[11px] font-normal text-muted-foreground">{{ c.ventesAnnulees }}/{{ c.ventesBillets }}</span>
                    </td>
                    <td class="p-3 text-center tabular-nums text-xs space-x-2">
                        <span class="{{ c.annulTickets > 0 ? '' : 'text-muted-foreground/40' }}">T·{{ c.annulTickets }}</span>
                        <span class="{{ c.annulBagages > 0 ? '' : 'text-muted-foreground/40' }}">B·{{ c.annulBagages }}</span>
                        <span class="{{ c.annulCourriers > 0 ? '' : 'text-muted-foreground/40' }}">C·{{ c.annulCourriers }}</span>
                    </td>
                    <td class="p-3 text-center tabular-nums text-xs space-x-2 {{ totalSuppr > 0 ? 'text-red-600 dark:text-red-400 font-semibold' : '' }}">
                        <span class="{{ c.supprTickets > 0 ? '' : 'text-muted-foreground/40 font-normal' }}">T·{{ c.supprTickets }}</span>
                        <span class="{{ c.supprBagages > 0 ? '' : 'text-muted-foreground/40 font-normal' }}">B·{{ c.supprBagages }}</span>
                        <span class="{{ c.supprCourriers > 0 ? '' : 'text-muted-foreground/40 font-normal' }}">C·{{ c.supprCourriers }}</span>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</section>
{% endif %}
{% endblock %}
