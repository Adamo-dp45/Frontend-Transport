{% extends 'base.html.twig' %}
{% import 'home/_stats.html.twig' as s %}

{% block title %}Billetterie{% endblock %}

{% block body %}
{{ s.pageHeader('Billetterie', 'Statistiques', 'owner.billetterie', debut, fin, 'stats.export.billetterie') }}

{% set rG = billetterie.recetteGuichet ?? 0 %}
{% set rC = billetterie.recetteCommercial ?? 0 %}
{% set rR = billetterie.recetteReservation ?? 0 %}
{# Panier moyen sur les ventes DIRECTES (guichet + commercial), la réservation étant un canal à part #}
{% set panier = billetterie.totalTickets > 0 ? ((rG + rC) / billetterie.totalTickets)|round : 0 %}

<section class="mb-10">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3 mb-6">
        {{ s.kpi('Total tickets', billetterie.totalTickets, '', 'blue', 'ticket') }}
        {{ s.kpi('Recette totale', billetterie.recetteTotale|number_format(0, ',', ' '), 'FCFA', 'emerald', 'money') }}
        {{ s.kpi('Panier moyen', panier|number_format(0, ',', ' '), 'FCFA', 'violet', 'scale') }}
        {{ s.kpi('Désistements', details.desistements.total ?? 0, (details.desistements.taux ?? 0) ~ ' %', 'rose', 'alert') }}
    </div>

    {# Ventilation de la recette billets par canal : guichet / commercial (à bord) / réservation (payée) #}
    {% set cTot = rG + rC + rR %}
    {% if cTot > 0 %}
    <div class="card p-4 mb-6">
        <p class="text-xs text-muted-foreground mb-2.5">Recette par canal de vente</p>
        <div class="flex h-2.5 w-full overflow-hidden rounded-full bg-muted mb-3">
            <div class="bg-emerald-500" style="width: {{ rG / cTot * 100 }}%"></div>
            <div class="bg-indigo-500" style="width: {{ rC / cTot * 100 }}%"></div>
            <div class="bg-violet-500" style="width: {{ rR / cTot * 100 }}%"></div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 text-sm">
            <div>
                <p class="flex items-center gap-1.5 text-xs text-muted-foreground"><span class="size-2 rounded-full bg-emerald-500"></span> Guichet (gare)</p>
                <p class="font-semibold tabular-nums mt-0.5">{{ rG|number_format(0, ',', ' ') }} <span class="text-xs font-normal text-muted-foreground">F</span></p>
            </div>
            <div>
                <p class="flex items-center gap-1.5 text-xs text-muted-foreground"><span class="size-2 rounded-full bg-indigo-500"></span> À bord (commercial)</p>
                <p class="font-semibold tabular-nums mt-0.5">{{ rC|number_format(0, ',', ' ') }} <span class="text-xs font-normal text-muted-foreground">F</span></p>
            </div>
            <div>
                <p class="flex items-center gap-1.5 text-xs text-muted-foreground"><span class="size-2 rounded-full bg-violet-500"></span> Réservation (payée)</p>
                <p class="font-semibold tabular-nums mt-0.5">{{ rR|number_format(0, ',', ' ') }} <span class="text-xs font-normal text-muted-foreground">F</span></p>
            </div>
        </div>
    </div>
    {% endif %}

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="card p-5 md:col-span-2">
            <p class="text-sm font-medium text-muted-foreground mb-4">Recettes par jour</p>
            <canvas id="chartBilleterieParJour" height="100"
                data-values="{{ billetterie.recettesParJour | map(r => {label: r.label, montant: r.montant, nbtickets: r.nbtickets}) | json_encode }}">
            </canvas>
        </div>
        <div class="card p-5">
            <p class="text-sm font-medium text-muted-foreground mb-4">Recettes par trajet</p>
            <canvas id="chartBilleterieParTrajet" height="160"
                data-values="{{ billetterie.recettesParTrajet | map(r => {trajet: r.trajet, montant: r.montant, nbtickets: r.nbtickets}) | json_encode }}">
            </canvas>
        </div>
        <div class="card p-5">
            <p class="text-sm font-medium text-muted-foreground mb-4">Recettes par car</p>
            <canvas id="chartBilleterieParCar" height="160"
                data-values="{{ billetterie.recettesParCar | map(r => {matricule: r.matricule, montant: r.montant, nbtickets: r.nbtickets}) | json_encode }}">
            </canvas>
        </div>
    </div>
</section>

{# ── Désistements & Remises ──────────────────────────────────────── #}
<section class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
    {% set ds = details.desistements %}
    <div class="card p-5">
        <p class="text-sm font-medium text-muted-foreground mb-4">Désistements (reports / annulations)</p>
        <div class="flex flex-wrap gap-6">
            <div><p class="text-2xl font-semibold tabular-nums text-amber-600 dark:text-amber-400">{{ ds.reporte ?? 0 }}</p><p class="text-xs text-muted-foreground">Reportés</p></div>
            <div><p class="text-2xl font-semibold tabular-nums text-red-600 dark:text-red-400">{{ ds.annule ?? 0 }}</p><p class="text-xs text-muted-foreground">Annulés (remboursés)</p></div>
            <div><p class="text-2xl font-semibold tabular-nums">{{ ds.valide ?? 0 }}</p><p class="text-xs text-muted-foreground">Validés</p></div>
        </div>
        <p class="text-xs text-muted-foreground mt-4 pt-3 border-t border-border">Taux de désistement : <strong class="text-foreground">{{ ds.taux ?? 0 }} %</strong> des billets émis sur la période</p>
        {% set annulAg = ds.parAgent ?? [] %}
        {% if annulAg|length > 0 %}
        <p class="text-xs text-muted-foreground mt-3 mb-1">Annulations par agent <span class="opacity-70">· montant remboursé</span></p>
        <div class="text-xs space-y-1">
            {% for a in annulAg|slice(0, 6) %}
            <div class="flex justify-between gap-2">
                <span class="truncate">{{ a.nom }} <span class="text-muted-foreground">· {{ a.nb }}</span>{% if (a.nbself ?? 0) > 0 %} <span class="ml-1 px-1.5 py-0.5 rounded-full bg-red-500/10 text-red-600 dark:text-red-400" title="Billets vendus ET annulés par le même agent">⚠ {{ a.nbself }} auto-annulé{{ a.nbself > 1 ? 's' : '' }}</span>{% endif %}</span>
                <span class="tabular-nums shrink-0">{{ a.montant|number_format(0, ',', ' ') }} F</span>
            </div>
            {% endfor %}
        </div>
        {% endif %}
        {% set supprAg = ds.suppressions ?? [] %}
        {% if supprAg|length > 0 %}
        <p class="text-xs text-muted-foreground mt-3 mb-1">Suppressions par agent <span class="opacity-70">· billets retirés du livre</span></p>
        <div class="text-xs space-y-1">
            {% for a in supprAg|slice(0, 6) %}
            <div class="flex justify-between gap-2">
                <span class="truncate">{{ a.nom }} <span class="text-muted-foreground">· {{ a.nb }}</span>{% if (a.nbapresdepart ?? 0) > 0 %} <span class="ml-1 px-1.5 py-0.5 rounded-full bg-red-500/10 text-red-600 dark:text-red-400" title="Billets supprimés APRÈS le départ du car (le passager avait voyagé)">⚠ {{ a.nbapresdepart }} après départ</span>{% endif %}</span>
                <span class="tabular-nums shrink-0">{{ a.montant|number_format(0, ',', ' ') }} F</span>
            </div>
            {% endfor %}
        </div>
        {% endif %}
    </div>

    <div class="card p-5">
        <p class="text-sm font-medium text-muted-foreground mb-1">Remises accordées</p>
        <p class="text-2xl font-semibold tabular-nums">{{ (details.remises.total ?? 0)|number_format(0, ',', ' ') }} <span class="text-sm font-normal text-muted-foreground">FCFA</span></p>
        <p class="text-xs text-muted-foreground mb-4">{{ details.remises.nb ?? 0 }} billet(s) remisé(s) · moyenne {{ (details.remises.remiseMoyenne ?? 0)|number_format(0, ',', ' ') }} F · <strong class="text-foreground">{{ details.remises.tauxBillets ?? 0 }} %</strong> des billets · <strong class="text-foreground">{{ details.remises.tauxMontant ?? 0 }} %</strong> du chiffre brut</p>
        {% if (details.remises.nb ?? 0) > 0 %}
        {% set cats = details.remises.parCategorie ?? [] %}
        {% if cats|length > 0 %}
        {% set maxCat = cats|first.total %}
        <p class="text-xs text-muted-foreground mb-1.5">Par catégorie de bénéficiaire</p>
        <div class="space-y-1.5 mb-3">
            {% for c in cats %}
            <div>
                <div class="flex justify-between text-xs mb-0.5"><span>{{ c.categorie }}</span><span class="tabular-nums">{{ c.total|number_format(0, ',', ' ') }} F</span></div>
                <div class="h-1.5 bg-muted rounded-full overflow-hidden"><div class="h-1.5 bg-violet-500 rounded-full" style="width: {{ maxCat > 0 ? (c.total / maxCat * 100) : 0 }}%"></div></div>
            </div>
            {% endfor %}
        </div>
        {% endif %}
        {% set benefs = details.remises.parBeneficiaire ?? [] %}
        {% if benefs|length > 0 %}
        <p class="text-xs text-muted-foreground mb-1">Top bénéficiaires</p>
        <div class="text-xs space-y-1">
            {% for b in benefs|slice(0, 5) %}
            <div class="flex justify-between gap-2"><span class="truncate">{{ b.nom }}{% if b.categorie %} <span class="text-muted-foreground">· {{ b.categorie }}</span>{% endif %}</span><span class="tabular-nums shrink-0">{{ b.total|number_format(0, ',', ' ') }} F</span></div>
            {% endfor %}
        </div>
        {% endif %}
        {% set ags = details.remises.parAgent ?? [] %}
        {% if ags|length > 0 %}
        <p class="text-xs text-muted-foreground mt-3 mb-1">Par agent <span class="opacity-70">· guichet</span></p>
        <div class="text-xs space-y-1">
            {% for a in ags|slice(0, 5) %}
            <div class="flex justify-between gap-2"><span class="truncate">{{ a.nom }} <span class="text-muted-foreground">· {{ a.nb }}</span></span><span class="tabular-nums shrink-0">{{ a.total|number_format(0, ',', ' ') }} F</span></div>
            {% endfor %}
        </div>
        {% endif %}
        {% set coms = details.remises.parCommercial ?? [] %}
        {% if coms|length > 0 %}
        <p class="text-xs text-muted-foreground mt-3 mb-1">Par commercial <span class="opacity-70">· à bord</span></p>
        <div class="text-xs space-y-1">
            {% for c in coms|slice(0, 5) %}
            <div class="flex justify-between gap-2"><span class="truncate">{{ c.nom }} <span class="text-muted-foreground">· {{ c.nb }}</span></span><span class="tabular-nums shrink-0">{{ c.total|number_format(0, ',', ' ') }} F</span></div>
            {% endfor %}
        </div>
        {% endif %}
        {% else %}<p class="text-xs text-muted-foreground">Aucune remise sur la période</p>{% endif %}
    </div>
</section>

{# ── Matrice Origine-Destination ─────────────────────────────────── #}
{% set odGares = details.matriceOD.gares ?? [] %}
{% set odCells = details.matriceOD.cells ?? {} %}
{% if odGares|length > 0 %}
{% set maxCell = 0 %}
{% for o in odGares %}{% for d in odGares %}{% set v = (odCells[o.id] ?? {})[d.id] ?? 0 %}{% if v > maxCell %}{% set maxCell = v %}{% endif %}{% endfor %}{% endfor %}
<section class="card p-5 mb-4">
    <p class="text-sm font-medium text-muted-foreground mb-1">Matrice Origine → Destination</p>
    <p class="text-xs text-muted-foreground mb-4">Nombre de billets par couple (ligne = montée, colonne = descente)</p>
    <div class="overflow-x-auto">
        <table class="text-sm border-collapse">
            <thead>
                <tr>
                    <th class="p-2 text-left text-xs font-medium text-muted-foreground sticky left-0 bg-card">De \ Vers</th>
                    {% for d in odGares %}<th class="p-2 text-center text-xs font-medium text-muted-foreground min-w-[64px]">{{ d.libelle }}</th>{% endfor %}
                </tr>
            </thead>
            <tbody>
                {% for o in odGares %}
                <tr>
                    <td class="p-2 text-xs font-medium whitespace-nowrap sticky left-0 bg-card">{{ o.libelle }}</td>
                    {% for d in odGares %}
                    {% set v = (odCells[o.id] ?? {})[d.id] ?? 0 %}
                    <td class="p-2 text-center tabular-nums border border-border/50" style="background-color: rgba(16,185,129,{{ (o.id == d.id or maxCell == 0) ? 0 : (v / maxCell * 0.75)|round(2) }})">
                        <span class="{{ v > 0 ? 'font-medium' : 'text-muted-foreground/40' }}">{{ o.id == d.id ? '—' : (v ?: '·') }}</span>
                    </td>
                    {% endfor %}
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</section>
{% endif %}

{# ── Heures de pointe ────────────────────────────────────────────── #}
{% set heures = details.heures ?? [] %}
{% if heures|length > 0 %}
{% set maxH = max(heures|map(h => h.nb)) %}
<section class="card p-5 mb-4">
    <p class="text-sm font-medium text-muted-foreground mb-4">Heures de pointe <span class="text-xs font-normal">(billets émis par heure)</span></p>
    <div class="flex items-end gap-1 h-32">
        {% for h in heures %}
        <div class="flex-1 h-full flex items-end" title="{{ h.heure }}h : {{ h.nb }} billet(s)">
            <div class="w-full rounded-t bg-blue-500/80 hover:bg-blue-600 transition-colors" style="height: {{ maxH > 0 ? (h.nb / maxH * 100) : 0 }}%; min-height: {{ h.nb > 0 ? '3px' : '0' }}"></div>
        </div>
        {% endfor %}
    </div>
    <div class="flex gap-1 mt-1">
        {% for h in heures %}<div class="flex-1 text-center text-[9px] text-muted-foreground">{{ h.heure % 3 == 0 ? h.heure ~ 'h' : '' }}</div>{% endfor %}
    </div>
</section>
{% endif %}
{% endblock %}
