{% extends 'base.html.twig' %}

{% block title %}Programme de fidélité{% endblock %}

{% block body %}
<div class="max-w-[700px] mx-auto">
    <div class="flex items-center gap-3 mb-1">
        <h1 class="text-3xl font-light tracking-[-0.55px] leading-[1.2]">Programme de fidélité</h1>
    </div>
    <p class="text-sm text-muted-foreground mb-5">
        Carte à tampons : tous les <strong>{{ programme.seuil }}</strong> voyages payés, le client membre gagne
        {{ programme.recompensePourcentage == 100 ? 'un voyage offert' : 'une réduction de ' ~ programme.recompensePourcentage ~ '%' }}.
    </p>

    <div class="rounded-xl border bg-card shadow-sm p-6">
        {{ form_start(form) }}
            <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 mb-3">
                <div>{{ form_row(form.seuil) }}</div>
                <div>{{ form_row(form.recompensePourcentage) }}</div>
                <div class="sm:col-span-2">{{ form_row(form.actif) }}</div>
            </div>
            <div class="flex items-center justify-end gap-3 mt-6 pt-4 border-t border-border">
                <button class="btn btn-primary">Enregistrer</button>
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
