{% extends 'base.html.twig' %}

{% block title %}Système{% endblock %}

{% block body %}
<div class="max-w-[700px] mx-auto">
    <div class="flex items-center gap-3 mb-1">
        <h1 class="text-3xl font-light tracking-[-0.55px] leading-[1.2]">Système</h1>
    </div>
    <p class="text-sm text-muted-foreground mb-5">Réglages plateforme réservés au super administrateur.</p>

    <div class="rounded-xl border bg-card shadow-sm p-6">
        <div class="flex items-start justify-between gap-3 mb-4">
            <div>
                <h2 class="text-lg font-medium">Mode maintenance</h2>
                <p class="text-sm text-muted-foreground">Ferme l'application à tous, sauf au super admin (interface + API).</p>
            </div>
            {% if (etat.actif ?? false) %}
            <span class="shrink-0 text-xs px-2.5 py-1 rounded-full bg-orange-500/10 text-orange-600 dark:text-orange-400 font-medium">● Actif{% if etat.depuis %} · depuis {{ etat.depuis|date('d/m/Y H:i') }}{% endif %}</span>
            {% else %}
            <span class="shrink-0 text-xs px-2.5 py-1 rounded-full bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 font-medium">● Application ouverte</span>
            {% endif %}
        </div>

        {{ form_start(form) }}
            <div class="mb-4">{{ form_row(form.actif) }}</div>
            <div class="mb-3">{{ form_row(form.message) }}</div>
            <div class="flex items-center justify-end gap-3 mt-6 pt-4 border-t border-border">
                <button class="btn btn-primary">Enregistrer</button>
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
