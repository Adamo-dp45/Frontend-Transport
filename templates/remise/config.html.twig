{% extends 'base.html.twig' %}

{% block title %}Configuration des remises{% endblock %}

{% block body %}
<div class="max-w-[700px] mx-auto">
    <div class="flex items-center gap-3 mb-1">
        <h1 class="text-3xl font-light tracking-[-0.55px] leading-[1.2]">Configuration des remises</h1>
    </div>
    <p class="text-sm text-muted-foreground mb-5">
        {% if (config.maxpourcentage ?? null) is not null %}
        Une remise manuelle ne peut dépasser <strong>{{ config.maxpourcentage }}%</strong> du tarif ; au-delà, la vente est refusée.
        {% else %}
        Aucun plafond de remise défini — les vendeurs peuvent appliquer n'importe quelle remise.
        {% endif %}
        Les récompenses fidélité ne sont pas concernées.
    </p>

    <div class="rounded-xl border bg-card shadow-sm p-6">
        {{ form_start(form) }}
            <div class="mb-3">{{ form_row(form.maxpourcentage) }}</div>
            <div class="flex items-center justify-end gap-3 mt-6 pt-4 border-t border-border">
                <button class="btn btn-primary">Enregistrer</button>
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
