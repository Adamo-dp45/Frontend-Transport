{% extends 'base.html.twig' %}

{% block title %}La liste des clients{% endblock %}

{% block body %}
<div class="flex items-start justify-between gap-4 max-sm:flex-col max-sm:gap-3 mb-5">
    <div>
        <h1 class="text-4xl font-light tracking-[-0.55px] leading-[1.2]">Gestion des clients</h1>
        <p class="text-sm text-muted-foreground mt-1">Le fichier client se construit automatiquement à la vente des billets (identifié par téléphone).</p>
    </div>
    <div class="flex items-center gap-2 shrink-0 max-sm:w-full">
        {% if is_granted('CLIENT_CREER') %}
        <a href="{{ path('client.new') }}" class="btn btn-primary max-sm:flex-1 max-sm:justify-center">
            <svg class="h-4 w-4" aria-hidden="true">
                <use href="{{ asset('sprite.svg') }}#new"></use>
            </svg>
            Nouveau client
        </a>
        {% endif %}
    </div>
</div>

<div {{ react_component('Billetterie/ClientTable', {
        clients: items,
        meta: meta,
        queryParams: queryParams,
        canEdit: is_granted('CLIENT_MODIFIER'),
        canDelete: is_granted('CLIENT_SUPPRIMER'),
        csrfDelete: csrf_token('delete_client'),
        csrfAdherer: csrf_token('adherer_fidelite'),
        csrfResilier: csrf_token('resilier_fidelite')
    }) }} class="mb-3"
>
    <div class="flex items-center justify-center gap-6">
        <twig:Spinner class="size-8" />
    </div>
</div>
{% endblock %}
